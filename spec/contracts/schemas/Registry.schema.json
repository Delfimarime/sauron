{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.raitonbl.com/schemas/v1/Registry.schema.json",
  "title": "Registry",
  "description": "The single registered source of artifacts, persisted in settings.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "sauron.raitonbl.com/v1" },
    "kind": { "const": "Registry" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unused for the single registry; retained for envelope uniformity."
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC3339 UTC timestamp stamped by sauron when the document was created; never hand-edited."
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC3339 UTC timestamp stamped by sauron on the document's most recent write; never hand-edited."
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "source"],
      "properties": {
        "transport": { "enum": ["git", "http", "filesystem"] },
        "source": { "type": "string", "minLength": 1 },
        "revision": {
          "type": "string",
          "minLength": 1,
          "description": "Git revision (branch, tag, or commit) to resolve artifacts from; git transport only. Absent means the repository's default branch."
        },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "description": "Credentials as environment references only (${env:VAR}); never resolved secrets.",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "skipVerify": { "type": "boolean" },
            "caCert": { "type": "string" },
            "clientCert": { "type": "string" },
            "clientKey": { "type": "string" }
          }
        },
        "sshKey": { "type": "string" },
        "timeout": {
          "type": "string",
          "description": "Go duration string bounding network operations (default 30s).",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$"
        }
      }
    }
  }
}
