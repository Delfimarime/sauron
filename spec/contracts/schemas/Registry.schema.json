{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.raitonbl.com/schemas/v1/Registry.schema.json",
  "title": "Registry",
  "description": "A registered source of artifacts, persisted in registries.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "sauron.raitonbl.com/v1" },
    "kind": { "const": "Registry" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique, path-safe registry name; the namespacing segment in sauron-<registry>-<name>.",
          "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "uri"],
      "properties": {
        "transport": { "enum": ["git", "http", "filesystem"] },
        "uri": { "type": "string", "minLength": 1 },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Git ref (branch, tag, or commit) to resolve artifacts from; git transport only. Absent means the repository's default branch."
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "description": "Credentials as environment references only (${env:VAR}); never resolved secrets.",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "skipVerify": { "type": "boolean" },
            "caCert": { "type": "string" },
            "clientCert": { "type": "string" },
            "clientKey": { "type": "string" }
          }
        },
        "sshKey": { "type": "string" },
        "timeout": {
          "type": "string",
          "description": "Go duration string bounding network operations (default 30s).",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)$"
        }
      }
    }
  }
}
