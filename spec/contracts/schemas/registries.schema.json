{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.dev/schemas/registries.schema.json",
  "title": "Sauron registries.yaml",
  "description": "The registered artifact sources. See spec/contracts/configuration.md#registriesyaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/registry" }
    }
  },
  "$defs": {
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "priority", "uri"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "kind": { "enum": ["http", "filesystem", "git"] },
        "priority": { "type": "integer", "minimum": 0 },
        "uri": { "type": "string", "minLength": 1 },
        "auth": { "$ref": "#/$defs/auth" },
        "tls": { "$ref": "#/$defs/tls" },
        "ssh": { "$ref": "#/$defs/ssh" },
        "timeout": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "filesystem" } } },
          "then": { "not": { "anyOf": [
            { "required": ["auth"] }, { "required": ["tls"] },
            { "required": ["ssh"] }, { "required": ["timeout"] }
          ] } }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "http" } } },
          "then": { "not": { "required": ["ssh"] } }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "git" } } },
          "then": { "not": { "anyOf": [ { "required": ["auth"] }, { "required": ["tls"] } ] } }
        }
      ]
    },
    "envRef": { "type": "string", "pattern": "^\\$\\{env:[A-Za-z_][A-Za-z0-9_]*\\}$" },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "basic" },
        "username": { "$ref": "#/$defs/envRef" },
        "password": { "$ref": "#/$defs/envRef" }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skip_verify": { "type": "boolean" },
        "ca_cert": { "type": "string" },
        "client_cert": { "type": "string" },
        "client_key": { "type": "string" }
      }
    },
    "ssh": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_path": { "type": "string" }
      }
    }
  }
}
