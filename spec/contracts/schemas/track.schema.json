{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.dev/schemas/track.schema.json",
  "title": "Sauron track.yaml",
  "description": "The installed artifacts and their provenance. See spec/contracts/configuration.md#trackyaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "provider", "path", "registry"],
      "properties": {
        "type": { "enum": ["skill", "agent"] },
        "name": { "type": "string", "minLength": 1 },
        "provider": { "enum": ["claude", "zencoder"] },
        "path": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "minLength": 1 },
        "persona": { "type": "string" }
      }
    }
  }
}
