{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.dev/schemas/backend.schema.json",
  "title": "Sauron backend.yaml",
  "description": "The singleton backend connection; fields at the root (no wrapper key). A file with only `version` means no backend is configured. See spec/contracts/configuration.md#backendyaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "dependentRequired": {
    "kind": ["uri"],
    "uri": ["kind"]
  },
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "kind": { "enum": ["http", "filesystem", "git"] },
    "uri": { "type": "string", "minLength": 1 },
    "auth": { "$ref": "#/$defs/auth" },
    "tls": { "$ref": "#/$defs/tls" },
    "ssh": { "$ref": "#/$defs/ssh" },
    "timeout": { "type": "string" },
    "last_synced_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "required": ["kind"], "properties": { "kind": { "const": "filesystem" } } },
      "then": { "not": { "anyOf": [
        { "required": ["auth"] }, { "required": ["tls"] },
        { "required": ["ssh"] }, { "required": ["timeout"] }
      ] } }
    },
    {
      "if": { "required": ["kind"], "properties": { "kind": { "const": "http" } } },
      "then": { "not": { "required": ["ssh"] } }
    },
    {
      "if": { "required": ["kind"], "properties": { "kind": { "const": "git" } } },
      "then": { "not": { "anyOf": [ { "required": ["auth"] }, { "required": ["tls"] } ] } }
    }
  ],
  "$defs": {
    "envRef": { "type": "string", "pattern": "^\\$\\{env:[A-Za-z_][A-Za-z0-9_]*\\}$" },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "basic" },
        "username": { "$ref": "#/$defs/envRef" },
        "password": { "$ref": "#/$defs/envRef" }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skip_verify": { "type": "boolean" },
        "ca_cert": { "type": "string" },
        "client_cert": { "type": "string" },
        "client_key": { "type": "string" }
      }
    },
    "ssh": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_path": { "type": "string" }
      }
    }
  }
}
