{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sauron.raitonbl.com/schemas/v1/Agent.schema.json",
  "title": "Agent",
  "description": "An installed agent, recorded in track.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "sauron.raitonbl.com/v1" },
    "kind": { "const": "Agent" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC3339 UTC timestamp stamped by sauron when the document was created; never hand-edited."
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC3339 UTC timestamp stamped by sauron on the document's most recent write; never hand-edited."
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "path", "installedAt", "updatedAt"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Identity read from the source — the artifact directory's git tree hash, or the http object version — compared by sync and upgrade to detect change."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Exact installed location relative to the provider root (sauron-<name>)."
        },
        "installedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
